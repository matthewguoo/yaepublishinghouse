generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  emailVerified Boolean   @default(false)
  isAdmin       Boolean   @default(false)
  verifyToken   String?   @unique
  verifyExpires DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  sessions         Session[]
  vouchers         Voucher[]
  mediaSubmissions MediaSubmission[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RateLimit {
  id        String   @id
  count     Int      @default(0)
  expiresAt DateTime
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String
  productId String
  createdAt DateTime @default(now())
  
  @@unique([email, productId])
}



model Article {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  date      String
  category  String
  excerpt   String
  content   String
  published Boolean  @default(false)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Voucher {
  id        String    @id @default(cuid())
  code      String    @unique
  value     Decimal   @db.Decimal(10, 2)
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model MediaSubmission {
  id         String    @id @default(cuid())
  userId     String
  mediaUrl   String
  platform   String
  status     String    @default("pending")
  rewardType String
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, createdAt])
}
