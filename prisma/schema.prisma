generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  emailVerified Boolean   @default(false)
  isAdmin       Boolean   @default(false)
  verifyToken   String?   @unique
  verifyExpires DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  sessions         Session[]
  vouchers         Voucher[]
  mediaSubmissions MediaSubmission[]
  carts            Cart[]
  orders           Order[]
  keychainOrders   KeychainOrder[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RateLimit {
  id        String   @id
  count     Int      @default(0)
  expiresAt DateTime
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String
  productId String
  createdAt DateTime @default(now())
  
  @@unique([email, productId])
}



model Article {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  date      String
  category  String
  excerpt   String
  content   String
  published Boolean  @default(false)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Trip {
  id          String   @id @default(cuid())
  tripType    String   // "roundtrip" | "oneway" | "relocation"
  title       String?
  description String?
  photos      String[]
  date        DateTime // overall trip date for sorting
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  toLegs     TripLeg[] @relation("ToLegs")
  returnLegs TripLeg[] @relation("ReturnLegs")

  @@index([date])
}

model TripLeg {
  id              String   @id @default(cuid())
  type            String   // "flight" | "car"
  originCode      String
  originName      String
  originLat       Float
  originLng       Float
  destinationCode String
  destinationName String
  destinationLat  Float
  destinationLng  Float
  date            DateTime
  flightNumber    String?
  order           Int      @default(0)

  toTrip       Trip?   @relation("ToLegs", fields: [toTripId], references: [id], onDelete: Cascade)
  toTripId     String?
  returnTrip   Trip?   @relation("ReturnLegs", fields: [returnTripId], references: [id], onDelete: Cascade)
  returnTripId String?

  @@index([toTripId])
  @@index([returnTripId])
  @@index([date])
}

model Voucher {
  id        String    @id @default(cuid())
  code      String    @unique
  value     Decimal   @db.Decimal(10, 2)
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model MediaSubmission {
  id         String    @id @default(cuid())
  userId     String
  mediaUrl   String
  platform   String
  status     String    @default("pending")
  rewardType String
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, createdAt])
}

model Product {
  id              String   @id @default(cuid())
  slug            String   @unique
  sku             String?
  name            String
  subtitle        String?
  description     String
  price           String
  priceInCents    Int      @default(0) // actual price for Stripe
  originalPrice   String?
  badge           String?
  badgeType       String?
  images          String[]
  specs           String   // pipe-separated
  isLive          Boolean  @default(false) // false = email waitlist, true = checkout
  ctaType         String   @default("email") // "email" | "stripe" | "soldout" | "comingsoon"
  ctaButtonText   String?
  ctaSuccessText  String?
  ctaPriceId      String?  // Stripe Price ID
  ctaMessage      String?
  stock           Int?
  stockStatus     String?
  shippingText    String?
  serialRange     String?
  featured        Boolean  @default(false)
  published       Boolean  @default(true)
  announcementUrl String?
  watermarkTop    String?
  watermarkBottom String?
  timeline        Json?    // [{label, date, status}]
  meta            Json?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cartItems       CartItem[]
  orderItems      OrderItem[]

  @@index([published, sortOrder])
}

// Cart for both guest and logged-in users
model Cart {
  id        String   @id @default(cuid())
  userId    String?  // null for guest carts
  guestId   String?  // cookie-based ID for guests
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@unique([userId])
  @@index([guestId])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model Order {
  id                 String   @id @default(cuid())
  userId             String?  // null for guest orders
  email              String
  stripeSessionId    String?  @unique
  stripePaymentIntent String?
  status             String   @default("pending") // pending, paid, shipped, delivered, cancelled
  subtotalInCents    Int
  shippingInCents    Int      @default(0)
  taxInCents         Int      @default(0)
  totalInCents       Int
  shippingName       String?
  shippingAddress    Json?    // {line1, line2, city, state, postal_code, country}
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  paidAt             DateTime?
  shippedAt          DateTime?

  user               User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items              OrderItem[]

  @@index([userId])
  @@index([email])
  @@index([status])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String
  productName  String   // snapshot at time of order
  productSku   String?
  priceInCents Int
  quantity     Int
  createdAt    DateTime @default(now())

  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model KeychainOrder {
  id           String   @id @default(cuid())
  userId       String?
  name         String
  email        String
  handle       String?
  notes        String?
  fileName     String?
  quantity     Int
  designs      Int
  priceInCents Int
  previewPng   String?  @db.Text
  status       String   @default("new") // new | confirmed | in_production | shipped | cancelled
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model KeychainPromo {
  id            String    @id @default(cuid())
  code          String    @unique
  discountPct   Int       @default(50)
  maxUses       Int?
  timesUsed     Int       @default(0)
  expiresAt     DateTime?
  note          String?
  createdAt     DateTime  @default(now())

  @@index([code])
}
